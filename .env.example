# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LinkedIn OAuth App (from https://www.linkedin.com/developers/apps)
# Required scopes: r_ads, rw_ads, w_organization_social
# Only needed for: python main.py  (LinkedIn campaign agent)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8888/callback

# ─────────────────────────────────────────────────────────────────────────────
# Weekly Report Consolidation  (python main.py reports)
# ─────────────────────────────────────────────────────────────────────────────

# ClickUp personal API token (Settings → Apps → API Token)
CLICKUP_API_TOKEN=pk_live_your_clickup_token_here

# ClickUp Team/Workspace ID — visible in your workspace URL:
#   https://app.clickup.com/{WORKSPACE_ID}/...
CLICKUP_WORKSPACE_ID=your_team_id_here

# Path to your Google service account JSON key file.
# Setup:
#   1. Google Cloud Console → Enable "Google Docs API"
#   2. IAM & Admin → Service Accounts → Create → download JSON key
#   3. Save the file as google_sa_key.json in this project root
#   4. Share each target client Google Doc with the service account email (Editor)
#   5. Share each contractor source Google Doc with the same email (Viewer)
GOOGLE_SA_KEY_FILE=google_sa_key.json

# Client/contractor mapping — see report_config.yaml
# Structure:
#   clients:
#     - id: acme_corp
#       name: "Acme Corp"
#       google_doc_id: "1BxiMVs0XRA5..."   # client-facing target doc
#       contractors:
#         - name: "Alice Johnson"
#           source: clickup
#           clickup_doc_id: "abc123"
#           clickup_page_id: "page789"      # optional; auto-fetches first page
#         - name: "Bob Smith"
#           source: google_doc
#           google_doc_id: "1C2dNVs1YRB6..."
